<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_auto_fulfillment_log_tree" model="ir.ui.view">
        <field name="name">auto.fulfillment.log.tree</field>
        <field name="model">auto.fulfillment.log</field>
        <field name="arch" type="xml">
            <list string="Auto Fulfillment Logs">
                <field name="create_date"/>
                <field name="picking_id"/>
                <field name="product_id"/>
                <field name="source_company_id"/>
                <field name="destination_company_id"/>
                <field name="source_warehouse_id"/>
                <field name="quantity"/>
                <field name="fulfillment_type"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_auto_fulfillment_log_form" model="ir.ui.view">
        <field name="name">auto.fulfillment.log.form</field>
        <field name="model">auto.fulfillment.log</field>
        <field name="arch" type="xml">
            <form string="Auto Fulfillment Log">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="picking_id"/>
                            <field name="product_id"/>
                            <field name="quantity"/>
                            <field name="fulfillment_type"/>
                            <field name="state"/>
                        </group>
                        <group>
                            <field name="source_company_id"/>
                            <field name="destination_company_id"/>
                            <field name="source_warehouse_id"/>
                            <field name="internal_picking_id"/>
                            <field name="sale_order_id"/>
                            <field name="purchase_order_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_auto_fulfillment_log_pivot" model="ir.ui.view">
        <field name="name">auto.fulfillment.log.pivot</field>
        <field name="model">auto.fulfillment.log</field>
        <field name="arch" type="xml">
            <pivot string="Auto Fulfillment Analysis">
                <field name="fulfillment_type" type="row"/>
                <field name="source_company_id" type="row"/>
                <field name="source_warehouse_id" type="row"/>
                <field name="quantity" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_auto_fulfillment_log_graph" model="ir.ui.view">
        <field name="name">auto.fulfillment.log.graph</field>
        <field name="model">auto.fulfillment.log</field>
        <field name="arch" type="xml">
            <graph string="Auto Fulfillment Analysis" type="bar">
                <field name="source_warehouse_id"/>
                <field name="quantity" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_auto_fulfillment_logs" model="ir.actions.act_window">
        <field name="name">Auto Fulfillment Logs</field>
        <field name="res_model">auto.fulfillment.log</field>
        <field name="view_mode">list,form,pivot,graph</field>
    </record>

    <menuitem id="menu_auto_fulfillment_root"
              name="Auto Fulfillment"
              parent="stock.menu_stock_root"
              sequence="95"/>

    <menuitem id="menu_auto_fulfillment_logs"
              name="Logs"
              parent="menu_auto_fulfillment_root"
              action="action_auto_fulfillment_logs"
              sequence="10"/>

</odoo>