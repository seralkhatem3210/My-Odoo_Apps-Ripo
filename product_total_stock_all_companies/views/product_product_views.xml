    <record id="view_product_template_form_auto_fulfillment" model="ir.ui.view">
        <field name="name">product.template.form.auto.fulfillment</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='inventory']" position="inside">
                <group string="Cross-Company Fulfillment">
                    <field name="allow_auto_cross_company_fulfillment"/>
                    <field name="qty_all_companies" readonly="1"/>
                    <field name="free_qty_all_companies" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>


