    <record id="view_product_product_kanban_all_companies_stock" model="ir.ui.view">
        <field name="name">product.product.kanban.all.companies.stock</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_view_kanban_catalog"/>
        <field name="arch" type="xml">

            <xpath expr="//kanban" position="inside">
                <field name="qty_all_companies"/>
                <field name="free_qty_all_companies"/>
            </xpath>

            <xpath expr="//t[@t-name='card']//div[contains(@class, 'p-2') and contains(@class, 'd-flex') and contains(@class, 'flex-column')]" position="inside">
                <div class="mt-2 pt-2 border-top">
                    <div class="d-flex justify-content-between align-items-center small">
                        <span class="text-muted">All Companies On Hand</span>
                        <span class="fw-bold">
                            <field name="qty_all_companies"/>
                        </span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center small mt-1">
                        <span class="text-muted">All Companies Free</span>
                        <span class="fw-bold">
                            <field name="free_qty_all_companies"/>
                        </span>
                    </div>
                </div>
            </xpath>

        </field>
    </record>



    <record id="view_product_template_kanban_all_companies_stock" model="ir.ui.view">
        <field name="name">product.template.kanban.all.companies.stock</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_kanban_view"/>
        <field name="arch" type="xml">

            <!-- load field in kanban -->
            <xpath expr="//kanban" position="inside">
                <field name="qty_all_companies"/>
                <field name="free_qty_all_companies"/>
            </xpath>

            <!-- add display under price -->
            <xpath expr="//t[@t-name='card']//span[.//field[@name='list_price']]" position="after">
                <div class="text-muted mt-1">
                    <span>All Companies Qty On Hand: </span>
                    <strong><field name="qty_all_companies"/></strong>
                </div>
                <div class="text-muted">
                    <span>All Companies Free Qty: </span>
                    <strong><field name="free_qty_all_companies"/></strong>
                </div>
            </xpath>

        </field>
    </record>

